const std = import("std");

struct MyStruct {
    a: i32,
    b: bool,

    pub fn foo(self: *MyStruct) -> void {}
    pub fn bar() -> void {}
}

pub fn main() -> void {
    const intInfo = @typeinfo(i32);
    std.io.printf("TypeInfo: i32 bits %d signed %d\n", intInfo.bits, intInfo.is_signed);

    const uintInfo = @typeinfo(u8);
    std.io.printf("TypeInfo: i8 bits %d signed %d\n", uintInfo.bits, uintInfo.is_signed);

    const structInfo = @typeinfo(MyStruct);
    std.io.printf("TypeInfo: MyStruct fields %d methods %d\n", structInfo.fields.len, structInfo.methods.len);

    for (structInfo.fields) |field| {
        std.io.printf("TypeInfo: MyStruct field %s\n", field.name.ptr);
    }
    for (structInfo.methods) |method| {
        std.io.printf("TypeInfo: MyStruct method %s\n", method.name.ptr);
    }
}
