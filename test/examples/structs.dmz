// RUN: dmz %s -run | filecheck %s

// CHECK: 1
// CHECK-NEXT: 2
// CHECK-NEXT: 3
// CHECK-NEXT: 41
// CHECK-NEXT: 42
// CHECK-NEXT: 43

// CHECK-NOT: {{.*}}

struct Color {
    r: i32,
    g: i32,
    b: i32,
    pub fn print(n: *Color) -> void {
        printf("%d\n", n.r);
        printf("%d\n", n.g);
        printf("%d\n", n.b);
    }

    pub fn add(n: *Color, value: i32) -> Color {
        let aux: Color = {};
        aux.r = n.r + value;
        aux.g = n.g + value;
        aux.b = n.b + value;
        return aux;
    }
}

extern fn printf(fmt: *u8, ...) -> i32;

fn main() -> void {
    let c = Color{r: 1, g: 2, b: 3};
    c.print();
    let c2 = c.add(40);
    c2.print();
}