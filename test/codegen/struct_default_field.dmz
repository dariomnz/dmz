// RUN: dmz %s -llvm-dump 2>&1 | filecheck %s
// RUN: diff <(dmz %s -run 2>&1) <(echo -n -e 'Start main\none called\nStructWithDefault{2, 0, 1}\n')

extern fn printf(fmt: *u8, ...) -> i32;

fn one() -> i32 {
    printf("one called\n");
    return 1;
}

struct StructWithDefault {
    r: i32,
    g: i32 = 0,
    b: i32 = one(),
}

fn main() -> void {
    printf("Start main\n");
    let s = StructWithDefault{r: 2};
    printf("StructWithDefault{%d, %d, %d}\n", s.r, s.g, s.b);
}
// CHECK: define void @__builtin_main() {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %s = alloca %struct_default_field.StructWithDefault, align 8
// CHECK-NEXT:   %tmp.struct.struct_default_field.StructWithDefault = alloca %struct_default_field.StructWithDefault, align 8
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %s, i8 0, i64 12, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %tmp.struct.struct_default_field.StructWithDefault, i8 0, i64 12, i1 false)
// CHECK-NEXT:   %0 = call i32 (ptr, ...) @printf(ptr byref(i8) @global.str.1)
// CHECK-NEXT:   %1 = call i32 @struct_default_field.one()
// CHECK-NEXT:   %2 = getelementptr inbounds nuw %struct_default_field.StructWithDefault, ptr %tmp.struct.struct_default_field.StructWithDefault, i32 0, i32 0
// CHECK-NEXT:   store i32 2, ptr %2, align 4
// CHECK-NEXT:   %3 = getelementptr inbounds nuw %struct_default_field.StructWithDefault, ptr %tmp.struct.struct_default_field.StructWithDefault, i32 0, i32 1
// CHECK-NEXT:   store i32 0, ptr %3, align 4
// CHECK-NEXT:   %4 = getelementptr inbounds nuw %struct_default_field.StructWithDefault, ptr %tmp.struct.struct_default_field.StructWithDefault, i32 0, i32 2
// CHECK-NEXT:   store i32 %1, ptr %4, align 4
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 4 %s, ptr align 4 %tmp.struct.struct_default_field.StructWithDefault, i64 12, i1 false)
// CHECK-NEXT:   %5 = getelementptr inbounds nuw %struct_default_field.StructWithDefault, ptr %s, i32 0, i32 0
// CHECK-NEXT:   %6 = load i32, ptr %5, align 4
// CHECK-NEXT:   %7 = getelementptr inbounds nuw %struct_default_field.StructWithDefault, ptr %s, i32 0, i32 1
// CHECK-NEXT:   %8 = load i32, ptr %7, align 4
// CHECK-NEXT:   %9 = getelementptr inbounds nuw %struct_default_field.StructWithDefault, ptr %s, i32 0, i32 2
// CHECK-NEXT:   %10 = load i32, ptr %9, align 4
// CHECK-NEXT:   %11 = call i32 (ptr, ...) @printf(ptr byref(i8) @global.str.2, i32 %6, i32 %8, i32 %10)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }