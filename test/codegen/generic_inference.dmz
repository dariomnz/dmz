// RUN: dmz %s -run 2>&1 | filecheck %s

extern fn printf(fmt: *u8, ...) -> i32;

fn print_val<T>(val: T) -> void {
}

fn add<T>(a: T, b: T) -> T {
    return a + b;
}

fn main() -> void {
    let x = add(1, 2);
    if (x == 3) {
        printf("OK\n");
    } else {
        printf("FAILED %d\n", x);
    }
}

// CHECK: OK
