// CHECK-NEXT:   br i1 %26, label %if.true, label %if.exit
// CHECK-NEXT: 
// CHECK-NEXT: if.true:                                          ; preds = %catch.exit4
// CHECK-NEXT:   %27 = call i32 (i32, ptr, ...) @dprintf(i32 1, ptr byref(i8) @global.str.3)
// CHECK-NEXT:   br label %if.exit
// CHECK-NEXT: 
// CHECK-NEXT: if.exit:                                          ; preds = %if.true, %catch.exit4
// CHECK-NEXT:   %28 = getelementptr inbounds nuw %error.struct.i32, ptr %result, i32 0, i32 1
// CHECK-NEXT:   %29 = load ptr, ptr %28, align 8
// CHECK-NEXT:   %30 = ptrtoint ptr %29 to i64
// CHECK-NEXT:   %ptr.to.bool6 = icmp ne i64 %30, 0
// CHECK-NEXT:   br i1 %ptr.to.bool6, label %if.true.try7, label %if.exit.try8
// CHECK-NEXT: 
// CHECK-NEXT: if.true.try7:                                     ; preds = %if.exit
// CHECK-NEXT:   %31 = call i32 (ptr, ...) @printf(ptr @1, ptr %29)
// CHECK-NEXT:   call void @llvm.trap()
// CHECK-NEXT:   br label %if.exit.try8
