// RUN: dmz %s -llvm-dump 2>&1 | filecheck %s
// RUN: diff <(dmz %s -run 2>&1) <(echo -n -e "10\nERROR_TWO\nThere was no error\n10\nThere are an error\nNo error 10\nNo safe error 10\n")

const e = error {
    ERROR_ONE,
    ERROR_TWO,
    ERROR_THREE,
};
// CHECK: @error.str.SUCCESS = private constant [8 x i8] c"SUCCESS\00"
// CHECK-NEXT: @error.str.ERROR_ONE = private constant [10 x i8] c"ERROR_ONE\00"
// CHECK-NEXT: @error.str.ERROR_TWO = private constant [10 x i8] c"ERROR_TWO\00"
// CHECK-NEXT: @error.str.ERROR_THREE = private constant [12 x i8] c"ERROR_THREE\00"

fn foo(x: i32) -> !i32 {
    if (x == 1) {
        return e.ERROR_ONE;
    }
    return x;
}
// CHECK: define void @error_handle.foo(ptr sret(%error.struct.i32) %ret, i32 %0) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %x = alloca i32, align 4
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %x, i8 0, i64 4, i1 false)
// CHECK-NEXT:   store i32 %0, ptr %x, align 4
// CHECK-NEXT:   %1 = load i32, ptr %x, align 4
// CHECK-NEXT:   %2 = icmp eq i32 %1, 1
// CHECK-NEXT:   br i1 %2, label %if.true, label %if.exit
// CHECK-NEXT: 
// CHECK-NEXT: if.true:                                          ; preds = %entry
// CHECK-NEXT:   %3 = getelementptr inbounds nuw %error.struct.i32, ptr %ret, i32 0, i32 1
// CHECK-NEXT:   store ptr @error.str.ERROR_ONE, ptr %3, align 8
// CHECK-NEXT:   br label %return
// CHECK-NEXT: 
// CHECK-NEXT: if.exit:                                          ; preds = %entry
// CHECK-NEXT:   %4 = load i32, ptr %x, align 4
// CHECK-NEXT:   store i32 %4, ptr %ret, align 4
// CHECK-NEXT:   br label %return
// CHECK-NEXT: 
// CHECK-NEXT: return:                                           ; preds = %if.exit, %if.true
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn bar(x: i32) -> !i32 {
    if (x == 2) {
        return e.ERROR_TWO;
    }
    return try foo(x);
}
// CHECK: define void @error_handle.bar(ptr sret(%error.struct.i32) %ret, i32 %0) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %x = alloca i32, align 4
// CHECK-NEXT:   %struct.ret.tmp = alloca %error.struct.i32, align 8
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %x, i8 0, i64 4, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %struct.ret.tmp, i8 0, i64 16, i1 false)
// CHECK-NEXT:   store i32 %0, ptr %x, align 4
// CHECK-NEXT:   %1 = load i32, ptr %x, align 4
// CHECK-NEXT:   %2 = icmp eq i32 %1, 2
// CHECK-NEXT:   br i1 %2, label %if.true, label %if.exit
// CHECK-NEXT: 
// CHECK-NEXT: if.true:                                          ; preds = %entry
// CHECK-NEXT:   %3 = getelementptr inbounds nuw %error.struct.i32, ptr %ret, i32 0, i32 1
// CHECK-NEXT:   store ptr @error.str.ERROR_TWO, ptr %3, align 8
// CHECK-NEXT:   br label %return
// CHECK-NEXT: 
// CHECK-NEXT: if.exit:                                          ; preds = %entry
// CHECK-NEXT:   %4 = load i32, ptr %x, align 4
// CHECK-NEXT:   call void @error_handle.foo(ptr sret(%error.struct.i32) %struct.ret.tmp, i32 %4)
// CHECK-NEXT:   %5 = getelementptr inbounds nuw %error.struct.i32, ptr %struct.ret.tmp, i32 0, i32 1
// CHECK-NEXT:   %6 = load ptr, ptr %5, align 8
// CHECK-NEXT:   %7 = ptrtoint ptr %6 to i64
// CHECK-NEXT:   %ptr.to.bool = icmp ne i64 %7, 0
// CHECK-NEXT:   br i1 %ptr.to.bool, label %if.true.try, label %if.exit.try
// CHECK-NEXT: 
// CHECK-NEXT: if.true.try:                                      ; preds = %if.exit
// CHECK-NEXT:   %8 = getelementptr inbounds nuw %error.struct.i32, ptr %ret, i32 0, i32 1
// CHECK-NEXT:   store ptr %6, ptr %8, align 8
// CHECK-NEXT:   br label %return
// CHECK-NEXT: 
// CHECK-NEXT: if.exit.try:                                      ; preds = %if.exit
// CHECK-NEXT:   %9 = getelementptr inbounds nuw %error.struct.i32, ptr %struct.ret.tmp, i32 0, i32 0
// CHECK-NEXT:   %10 = load i32, ptr %9, align 4
// CHECK-NEXT:   store i32 %10, ptr %ret, align 4
// CHECK-NEXT:   br label %return
// CHECK-NEXT: 
// CHECK-NEXT: return:                                           ; preds = %if.exit.try, %if.true.try, %if.true
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

extern fn dprintf(fd: i32, fmt: *u8, ...) -> i32;

fn voiderr(n: i32) -> !void {
    if (n == 0) {
        return e.ERROR_THREE;
    }
}

fn main() -> void {
    let result = foo(10);
    let result2 = bar(2);
    dprintf(1, "%d\n", try result);
    result2 catch |result_e| {
        dprintf(1, "%s\n", result_e);
    };

    let result_error = false;
    result catch |err1| {
        dprintf(1, "%s\n", err1);
        result_error = true;
    };

    if (!result_error) {
        dprintf(1, "There was no error\n");
    }

    dprintf(1, "%d\n", try result);

    result catch {
        dprintf(1, "There are an error\n");
    };
    foo(1) catch {
        dprintf(1, "There are an error\n");
    };

    dprintf(1, "No error %d\n", try result);
    dprintf(1, "No safe error %d\n", try foo(10));
}
// CHECK: define void @__builtin_main() {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %result = alloca %error.struct.i32, align 8
// CHECK-NEXT:   %struct.ret.tmp = alloca %error.struct.i32, align 8
// CHECK-NEXT:   %result2 = alloca %error.struct.i32, align 8
// CHECK-NEXT:   %struct.ret.tmp1 = alloca %error.struct.i32, align 8
// CHECK-NEXT:   %catch_result = alloca i32, align 4
// CHECK-NEXT:   %result_e = alloca ptr, align 8
// CHECK-NEXT:   %result_error = alloca i1, align 1
// CHECK-NEXT:   %catch_result5 = alloca i32, align 4
// CHECK-NEXT:   %err1 = alloca ptr, align 8
// CHECK-NEXT:   %catch_result12 = alloca i32, align 4
// CHECK-NEXT:   %catch_result16 = alloca i32, align 4
// CHECK-NEXT:   %struct.ret.tmp17 = alloca %error.struct.i32, align 8
// CHECK-NEXT:   %struct.ret.tmp21 = alloca %error.struct.i32, align 8
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %result, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %struct.ret.tmp, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %result2, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %struct.ret.tmp1, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %catch_result, i8 0, i64 4, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %result_e, i8 0, i64 8, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %result_error, i8 0, i64 1, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %catch_result5, i8 0, i64 4, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %err1, i8 0, i64 8, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %catch_result12, i8 0, i64 4, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %catch_result16, i8 0, i64 4, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %struct.ret.tmp17, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %struct.ret.tmp21, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @error_handle.foo(ptr sret(%error.struct.i32) %struct.ret.tmp, i32 10)
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 8 %result, ptr align 8 %struct.ret.tmp, i64 16, i1 false)
// CHECK-NEXT:   call void @error_handle.bar(ptr sret(%error.struct.i32) %struct.ret.tmp1, i32 2)
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 8 %result2, ptr align 8 %struct.ret.tmp1, i64 16, i1 false)
// CHECK-NEXT:   %0 = getelementptr inbounds nuw %error.struct.i32, ptr %result, i32 0, i32 1
// CHECK-NEXT:   %1 = load ptr, ptr %0, align 8
// CHECK-NEXT:   %2 = ptrtoint ptr %1 to i64
// CHECK-NEXT:   %ptr.to.bool = icmp ne i64 %2, 0
// CHECK-NEXT:   br i1 %ptr.to.bool, label %if.true.try, label %if.exit.try
// CHECK-NEXT: 
// CHECK-NEXT: if.true.try:                                      ; preds = %entry
// CHECK-NEXT:   %3 = call i32 (ptr, ...) @printf(ptr @0, ptr %1)
// CHECK-NEXT:   call void @llvm.trap()
// CHECK-NEXT:   br label %if.exit.try
// CHECK-NEXT: 
// CHECK-NEXT: if.exit.try:                                      ; preds = %if.true.try, %entry
// CHECK-NEXT:   %4 = getelementptr inbounds nuw %error.struct.i32, ptr %result, i32 0, i32 0
// CHECK-NEXT:   %5 = load i32, ptr %4, align 4
// CHECK-NEXT:   %6 = call i32 (i32, ptr, ...) @dprintf(i32 1, ptr byref(i8) @global.str, i32 %5)
// CHECK-NEXT:   %7 = getelementptr inbounds nuw %error.struct.i32, ptr %result2, i32 0, i32 1
// CHECK-NEXT:   %8 = load ptr, ptr %7, align 8
// CHECK-NEXT:   %9 = icmp ne ptr %8, null
// CHECK-NEXT:   br i1 %9, label %catch.has_error, label %catch.no_error
// CHECK-NEXT: 
// CHECK-NEXT: catch.no_error:                                   ; preds = %if.exit.try
// CHECK-NEXT:   %10 = getelementptr inbounds nuw %error.struct.i32, ptr %result2, i32 0, i32 0
// CHECK-NEXT:   %11 = load i32, ptr %10, align 4
// CHECK-NEXT:   store i32 %11, ptr %catch_result, align 4
// CHECK-NEXT:   br label %catch.exit
// CHECK-NEXT: 
// CHECK-NEXT: catch.has_error:                                  ; preds = %if.exit.try
// CHECK-NEXT:   %12 = load ptr, ptr %7, align 8
// CHECK-NEXT:   store ptr %12, ptr %result_e, align 8
// CHECK-NEXT:   %13 = load ptr, ptr %result_e, align 8
// CHECK-NEXT:   %14 = call i32 (i32, ptr, ...) @dprintf(i32 1, ptr byref(i8) @global.str.1, ptr %13)
// CHECK-NEXT:   br label %catch.exit
// CHECK-NEXT: 
// CHECK-NEXT: catch.exit:                                       ; preds = %catch.has_error, %catch.no_error
// CHECK-NEXT:   %15 = load i32, ptr %catch_result, align 4
// CHECK-NEXT:   store i1 false, ptr %result_error, align 1
// CHECK-NEXT:   %16 = getelementptr inbounds nuw %error.struct.i32, ptr %result, i32 0, i32 1
// CHECK-NEXT:   %17 = load ptr, ptr %16, align 8
// CHECK-NEXT:   %18 = icmp ne ptr %17, null
// CHECK-NEXT:   br i1 %18, label %catch.has_error3, label %catch.no_error2
// CHECK-NEXT: 
// CHECK-NEXT: catch.no_error2:                                  ; preds = %catch.exit
// CHECK-NEXT:   %19 = getelementptr inbounds nuw %error.struct.i32, ptr %result, i32 0, i32 0
