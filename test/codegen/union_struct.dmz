// RUN: dmz %s -run 2>&1 | filecheck %s

// CHECK: t.int_val == 5: 1
// CHECK-NEXT: int_val
// CHECK-NEXT: str_val
// CHECK-NEXT: t2.str_val[0] == 'h': 1
// CHECK-NEXT: struct_val
// CHECK-NEXT: t3.struct_val.a == 1: 1
// CHECK-NEXT: t3.struct_val.b == 2: 1

extern fn printf(fmt: *u8, ...) -> i32;

struct MyStruct {
    a: i32,
    b: i32,
}

union Token {
    int_val: i32,
    str_val: *u8,
    struct_val: MyStruct,

    pub fn print(self: *@This) -> void {
        switch (self.tag) {
            case Token.int_val => printf("int_val\n");
            case Token.str_val => printf("str_val\n");
            case Token.struct_val => printf("struct_val\n");
            else => printf("unknown\n");
        }
    }
}

fn main() -> void {
    let t = Token{int_val: 5};
    printf("t.int_val == 5: %d\n", t.int_val == 5);
    t.print();

    let t2 = Token{str_val: "hello"};
    t2.print();
    printf("t2.str_val[0] == 'h': %d\n", t2.str_val[0] == 'h');

    let t3 = Token{struct_val: MyStruct{a: 1, b: 2}};
    t3.print();
    printf("t3.struct_val.a == 1: %d\n", t3.struct_val.a == 1);
    printf("t3.struct_val.b == 2: %d\n", t3.struct_val.b == 2);
}