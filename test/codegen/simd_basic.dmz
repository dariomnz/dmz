// RUN: dmz %s -llvm-dump 2>&1 | filecheck %s

extern fn printf(fmt: *u8, ...) -> void;

fn main() -> void {
    let arr: i32[4] = {1, 2, 3, 4};
    let v: @simd<i32, 4> = @simd<i32, 4>.load(&arr[0]);

    let out: i32[4] = {0, 0, 0, 0};
    v.store(&out[0]);

    printf("v = %d %d %d %d\n", v[0], v[1], v[2], v[3]);
    printf("out = %d %d %d %d\n", out[0], out[1], out[2], out[3]);
}
// CHECK: define void @__builtin_main() {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %arr = alloca [4 x i32], align 4
// CHECK-NEXT:   %"array.i32[4].tmp" = alloca [4 x i32], align 4
// CHECK-NEXT:   %v = alloca <4 x i32>, align 16
// CHECK-NEXT:   %out = alloca [4 x i32], align 4
// CHECK-NEXT:   %"array.i32[4].tmp1" = alloca [4 x i32], align 4
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %arr, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %"array.i32[4].tmp", i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %v, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %out, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %"array.i32[4].tmp1", i8 0, i64 16, i1 false)
// CHECK-NEXT:   %0 = getelementptr [4 x i32], ptr %"array.i32[4].tmp", i32 0, i32 0
// CHECK-NEXT:   store i32 1, ptr %0, align 4
// CHECK-NEXT:   %1 = getelementptr [4 x i32], ptr %"array.i32[4].tmp", i32 0, i32 1
// CHECK-NEXT:   store i32 2, ptr %1, align 4
// CHECK-NEXT:   %2 = getelementptr [4 x i32], ptr %"array.i32[4].tmp", i32 0, i32 2
// CHECK-NEXT:   store i32 3, ptr %2, align 4
// CHECK-NEXT:   %3 = getelementptr [4 x i32], ptr %"array.i32[4].tmp", i32 0, i32 3
// CHECK-NEXT:   store i32 4, ptr %3, align 4
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 4 %arr, ptr align 4 %"array.i32[4].tmp", i64 16, i1 false)
// CHECK-NEXT:   %4 = getelementptr [4 x i32], ptr %arr, i32 0, i32 0
// CHECK-NEXT:   %simd.load = load <4 x i32>, ptr %4, align 16
// CHECK-NEXT:   store <4 x i32> %simd.load, ptr %v, align 16
// CHECK-NEXT:   %5 = getelementptr [4 x i32], ptr %"array.i32[4].tmp1", i32 0, i32 0
// CHECK-NEXT:   store i32 0, ptr %5, align 4
// CHECK-NEXT:   %6 = getelementptr [4 x i32], ptr %"array.i32[4].tmp1", i32 0, i32 1
// CHECK-NEXT:   store i32 0, ptr %6, align 4
// CHECK-NEXT:   %7 = getelementptr [4 x i32], ptr %"array.i32[4].tmp1", i32 0, i32 2
// CHECK-NEXT:   store i32 0, ptr %7, align 4
// CHECK-NEXT:   %8 = getelementptr [4 x i32], ptr %"array.i32[4].tmp1", i32 0, i32 3
// CHECK-NEXT:   store i32 0, ptr %8, align 4
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 4 %out, ptr align 4 %"array.i32[4].tmp1", i64 16, i1 false)
// CHECK-NEXT:   %9 = getelementptr [4 x i32], ptr %out, i32 0, i32 0
// CHECK-NEXT:   %10 = load <4 x i32>, ptr %v, align 16
// CHECK-NEXT:   store <4 x i32> %10, ptr %9, align 16
// CHECK-NEXT:   %11 = getelementptr <4 x i32>, ptr %v, i32 0, i32 0
// CHECK-NEXT:   %12 = load i32, ptr %11, align 4
// CHECK-NEXT:   %13 = getelementptr <4 x i32>, ptr %v, i32 0, i32 1
// CHECK-NEXT:   %14 = load i32, ptr %13, align 4
// CHECK-NEXT:   %15 = getelementptr <4 x i32>, ptr %v, i32 0, i32 2
// CHECK-NEXT:   %16 = load i32, ptr %15, align 4
// CHECK-NEXT:   %17 = getelementptr <4 x i32>, ptr %v, i32 0, i32 3
// CHECK-NEXT:   %18 = load i32, ptr %17, align 4
// CHECK-NEXT:   call void (ptr, ...) @printf(ptr byref(i8) @global.str, i32 %12, i32 %14, i32 %16, i32 %18)
// CHECK-NEXT:   %19 = getelementptr [4 x i32], ptr %out, i32 0, i32 0
// CHECK-NEXT:   %20 = load i32, ptr %19, align 4
// CHECK-NEXT:   %21 = getelementptr [4 x i32], ptr %out, i32 0, i32 1
// CHECK-NEXT:   %22 = load i32, ptr %21, align 4
// CHECK-NEXT:   %23 = getelementptr [4 x i32], ptr %out, i32 0, i32 2
// CHECK-NEXT:   %24 = load i32, ptr %23, align 4
// CHECK-NEXT:   %25 = getelementptr [4 x i32], ptr %out, i32 0, i32 3
// CHECK-NEXT:   %26 = load i32, ptr %25, align 4
// CHECK-NEXT:   call void (ptr, ...) @printf(ptr byref(i8) @global.str.1, i32 %20, i32 %22, i32 %24, i32 %26)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }