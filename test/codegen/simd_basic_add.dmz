// RUN: dmz %s -llvm-dump 2>&1 | filecheck %s

extern fn printf(fmt: *u8, ...) -> void;

fn main() -> void {
    let arr: i32[4] = {1, 2, 3, 4};
    let v: @simd<i32, 4> = @simd<i32, 4>.load(&arr[0]);
    let v2: @simd<i32, 4> = @simd<i32, 4>.load(&arr[0]);

    let v3 = v + v2;

    printf("sum = %d %d %d %d\n", v3[0], v3[1], v3[2], v3[3]);
}

// CHECK: define void @__builtin_main() {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %arr = alloca [4 x i32], align 4
// CHECK-NEXT:   %"array.i32[4].tmp" = alloca [4 x i32], align 4
// CHECK-NEXT:   %v = alloca <4 x i32>, align 16
// CHECK-NEXT:   %v2 = alloca <4 x i32>, align 16
// CHECK-NEXT:   %v3 = alloca <4 x i32>, align 16
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %arr, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %"array.i32[4].tmp", i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %v, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %v2, i8 0, i64 16, i1 false)
// CHECK-NEXT:   call void @llvm.memset.inline.p0.i64(ptr align 8 %v3, i8 0, i64 16, i1 false)
// CHECK-NEXT:   %0 = getelementptr [4 x i32], ptr %"array.i32[4].tmp", i32 0, i32 0
// CHECK-NEXT:   store i32 1, ptr %0, align 4
// CHECK-NEXT:   %1 = getelementptr [4 x i32], ptr %"array.i32[4].tmp", i32 0, i32 1
// CHECK-NEXT:   store i32 2, ptr %1, align 4
// CHECK-NEXT:   %2 = getelementptr [4 x i32], ptr %"array.i32[4].tmp", i32 0, i32 2
// CHECK-NEXT:   store i32 3, ptr %2, align 4
// CHECK-NEXT:   %3 = getelementptr [4 x i32], ptr %"array.i32[4].tmp", i32 0, i32 3
// CHECK-NEXT:   store i32 4, ptr %3, align 4
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 4 %arr, ptr align 4 %"array.i32[4].tmp", i64 16, i1 false)
// CHECK-NEXT:   %4 = getelementptr [4 x i32], ptr %arr, i32 0, i32 0
// CHECK-NEXT:   %simd.load = load <4 x i32>, ptr %4, align 16
// CHECK-NEXT:   store <4 x i32> %simd.load, ptr %v, align 16
// CHECK-NEXT:   %5 = getelementptr [4 x i32], ptr %arr, i32 0, i32 0
// CHECK-NEXT:   %simd.load1 = load <4 x i32>, ptr %5, align 16
// CHECK-NEXT:   store <4 x i32> %simd.load1, ptr %v2, align 16
// CHECK-NEXT:   %6 = load <4 x i32>, ptr %v, align 16
// CHECK-NEXT:   %7 = load <4 x i32>, ptr %v2, align 16
// CHECK-NEXT:   %8 = add <4 x i32> %6, %7
// CHECK-NEXT:   store <4 x i32> %8, ptr %v3, align 16
// CHECK-NEXT:   %9 = getelementptr <4 x i32>, ptr %v3, i32 0, i32 0
// CHECK-NEXT:   %10 = load i32, ptr %9, align 4
// CHECK-NEXT:   %11 = getelementptr <4 x i32>, ptr %v3, i32 0, i32 1
// CHECK-NEXT:   %12 = load i32, ptr %11, align 4
// CHECK-NEXT:   %13 = getelementptr <4 x i32>, ptr %v3, i32 0, i32 2
// CHECK-NEXT:   %14 = load i32, ptr %13, align 4
// CHECK-NEXT:   %15 = getelementptr <4 x i32>, ptr %v3, i32 0, i32 3
// CHECK-NEXT:   %16 = load i32, ptr %15, align 4
// CHECK-NEXT:   call void (ptr, ...) @printf(ptr byref(i8) @global.str, i32 %10, i32 %12, i32 %14, i32 %16)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }