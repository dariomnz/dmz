// RUN: dmz %s -res-dump 2>&1 | filecheck %s

fn foo<T>(slice: T) -> void {
    slice.len;
}

fn main() -> void {
    let a: i32[3] = {1, 2, 3};
    let s: []i32 = a[0..2];
    foo<s>(s);
}

// CHECK: ResolvedModuleDecl generic_slice
// CHECK-NEXT:   ResolvedGenericFunctionDecl foo fn(T)->void
// CHECK-NEXT:     ResolvedGenericTypeDecl T
// CHECK-NEXT:     ResolvedParamDecl:T slice
// CHECK-NEXT:     ResolvedBlock
// CHECK-NEXT:       ResolvedMemberExpr:generic len
// CHECK-NEXT:         ResolvedDeclRefExpr:T slice
// CHECK-NEXT:     ResolvedSpecializedFunctionDecl foo<[]i32> fn([]i32)->void
// CHECK-NEXT:       ResolvedParamDecl:[]i32 slice
// CHECK-NEXT:       ResolvedBlock
// CHECK-NEXT:         ResolvedMemberExpr:u64 len
// CHECK-NEXT:           ResolvedDeclRefExpr:[]i32 slice
// CHECK-NEXT:   ResolvedFunctionDecl main fn()->void
// CHECK-NEXT:     ResolvedBlock
// CHECK-NEXT:       ResolvedDeclStmt i32[3]
// CHECK-NEXT:         ResolvedVarDecl:i32[3] a
// CHECK-NEXT:           ResolvedArrayInstantiationExpr:i32[3]
// CHECK-NEXT:             ResolvedIntLiteral:i32 '1'
// CHECK-NEXT:             | value: 1
// CHECK-NEXT:             ResolvedIntLiteral:i32 '2'
// CHECK-NEXT:             | value: 2
// CHECK-NEXT:             ResolvedIntLiteral:i32 '3'
// CHECK-NEXT:             | value: 3
// CHECK-NEXT:       ResolvedDeclStmt []i32
// CHECK-NEXT:         ResolvedVarDecl:[]i32 s
// CHECK-NEXT:           ResolvedArrayAtExpr:[]i32
// CHECK-NEXT:             ResolvedDeclRefExpr:i32[3] a
// CHECK-NEXT:             ResolvedRangeExpr
// CHECK-NEXT:               ResolvedIntLiteral:i32 '0'
// CHECK-NEXT:               | value: 0
// CHECK-NEXT:               ResolvedIntLiteral:i32 '2'
// CHECK-NEXT:               | value: 2
// CHECK-NEXT:       ResolvedCallExpr:void
// CHECK-NEXT:         ResolvedGenericExpr:fn([]i32)->void foo
// CHECK-NEXT:           ResolvedDeclRefExpr:fn(T)->void foo
// CHECK-NEXT:           ResolvedTypeSpecialized <[]i32>
// CHECK-NEXT:         ResolvedDeclRefExpr:[]i32 s