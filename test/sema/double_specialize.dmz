// RUN: dmz %s -res-dump 2>&1 | filecheck %s

extern fn printf(fmt: *u8, ...) -> i32;

fn foo<K>(i: i32, arg: K) -> i32 {
    printf("foo %d %d\n", i, arg);
    if (i == 0) {
        return 0;
    }
    const t = @typeid(arg);
    inline switch (t) {
        case 1 => return bar<arg>(i - 1, arg);
        case 2 => return bar<arg>(i - 1, arg);
        else => return bar<arg>(i - 1, arg);
    }
}

fn bar<T>(i: i32, arg: T) -> i32 {
    printf("bar %d %d\n", i, arg);
    if (i == 0) {
        return 0;
    }
    foo<arg>(i - 1, arg);
    return 1;
}

fn main() -> void {
    bar(10, 1);
}
// CHECK: ResolvedModuleDecl double_specialize
// CHECK-NEXT:   ResolvedExternFunctionDecl printf fn(*u8, ...)->i32
// CHECK-NEXT:     ResolvedParamDecl:*u8 fmt
