// RUN: dmz %s -res-dump 2>&1 | filecheck %s

fn main() -> void {
    const x = 1;
    inline switch (x) {
        case 0 => let a = 0;
        case 1 => let b = 1;
        else => let c = 2;
    }
}
// CHECK: ResolvedModuleDecl inline_switch
// CHECK-NEXT:   ResolvedFunctionDecl main fn()->void
// CHECK-NEXT:     ResolvedBlock
// CHECK-NEXT:       ResolvedDeclStmt i32
// CHECK-NEXT:         ResolvedVarDecl:const i32 x
// CHECK-NEXT:           ResolvedIntLiteral:i32 '1'
// CHECK-NEXT:           | value: 1
// CHECK-NEXT:       ResolvedInlineSwitchStmt
// CHECK-NEXT:         ResolvedDeclRefExpr:i32 x
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:         ResolvedCaseStmt
// CHECK-NEXT:           ResolvedIntLiteral:i32 '0'
// CHECK-NEXT:           | value: 0
// CHECK-NEXT:           ResolvedBlock
// CHECK-NEXT:         ResolvedCaseStmt
// CHECK-NEXT:           ResolvedIntLiteral:i32 '1'
// CHECK-NEXT:           | value: 1
// CHECK-NEXT:           ResolvedBlock
// CHECK-NEXT:             ResolvedDeclStmt i32
// CHECK-NEXT:               ResolvedVarDecl:i32 b
// CHECK-NEXT:                 ResolvedIntLiteral:i32 '1'
// CHECK-NEXT:                 | value: 1
// CHECK-NEXT:         ElseBlock
// CHECK-NEXT:           ResolvedBlock