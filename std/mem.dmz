extern fn malloc(size: usize) -> *void;
extern fn realloc(ptr: *void, size: usize) -> *void;
extern fn free(ptr: *void) -> void;
pub extern fn memmove(dest: *void, src: *void, size: usize) -> *void;
pub extern fn memcpy(dest: *void, src: *void, size: usize) -> *void;
pub extern fn strlen(str: *u8) -> usize;
pub extern fn memcmp(buf1: *void, buf2: *void, size: usize) -> i32;

pub struct Allocator {
    allocator: *void,
    vtable_malloc: *fn(*void, usize)->*void,
    vtable_realloc: *fn(*void, *void, usize)->*void,
    vtable_free: *fn(*void, *void)->void,

    pub fn malloc(self: *@This, size: usize) -> *void {
        return self.vtable_malloc(self.allocator, size);
    }

    pub fn realloc(self: *@This, ptr: *void, size: usize) -> *void {
        return self.vtable_realloc(self.allocator, ptr, size);
    }

    pub fn free(self: *@This, ptr: *void) -> void {
        self.vtable_free(self.allocator, ptr);
    }
}

pub struct libc_allocator {
    allocated: usize,
    allocated_count: usize,

    pub fn init() -> @This {
        return @This{
            allocated: 0,
            allocated_count: 0,
        };
    }

    pub fn deinit(self: *@This) -> !void {
        if (self.allocated_count != 0) {
            return error.LeakMemory;
        }
    }

    fn malloc(self: *@This, size: usize) -> *void {
        self.allocated += size;
        self.allocated_count++;
        return malloc(size);
    }

    fn realloc(self: *@This, ptr: *void, size: usize) -> *void {
        self.allocated += size;
        return realloc(ptr, size);
    }

    fn free(self: *@This, ptr: *void) -> void {
        self.allocated_count--;
        free(ptr);
    }

    pub fn Allocator(self: *@This) -> Allocator {
        return Allocator{
            allocator: self,
            vtable_malloc: &self.malloc,
            vtable_realloc: &self.realloc,
            vtable_free: &self.free,
        };
    }
}

